{
  "author": "IBM",
  "name": "ibm-rmf",
  "version": "2.0.1",
  "description": "IBM RMF for z/OS",
  "license": "Apache-2.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --fix --cache .",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "format": "prettier-eslint --write '**/*.ts*'",
    "antlr": "antlr4-tool --help",
    "generate-parser": "antlr4-tool -Dlanguage=JavaScript -o src/datasource/parser/lib -Xexact-output-dir ./grammar/RMFQuery.g4",
    "generate-parser-java": "java -Xmx500M -cp '/usr/local/lib/antlr-4.10.1-complete.jar:$CLASSPATH' org.antlr.v4.Tool -Dlanguage=JavaScript -o src/datasource/parser/lib -Xexact-output-dir",
    "start": "yarn watch",
    "start-docker": "docker-compose up",
    "start-docker:dev": "docker-compose -f docker-compose/dev.yml pull && docker-compose -f docker-compose/dev.yml up",
    "start-docker:master": "docker-compose -f docker-compose/master.yml pull && docker-compose -f docker-compose/master.yml up",
    "stop-docker": "docker-compose down",
    "stop-docker:dev": "docker-compose -f docker-compose/dev.yml down",
    "test:debug": "jest --runInBand",
    "upgrade": "yarn upgrade --latest"
  },
  "devDependencies": {
    "@grafana/data": "13.0.1",
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/runtime": "13.0.1",
    "@grafana/tsconfig": "^2.1.0",
    "@grafana/ui": "13.0.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/enzyme": "^3.10.19",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "enzyme": "^3.11.0",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-webpack-plugin": "^6.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.3.1",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.2.0-rc.1",
    "webpack-virtual-modules": "^0.6.2"
  },
  "dependencies": {
    "antlr4": "^4.13.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.14.1"
}
